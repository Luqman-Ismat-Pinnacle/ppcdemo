# PPC Minimal — Production / Container env (align with legacy .env.local for Azure)
# Copy to .env.local for local dev. Set in Azure DevOps Pipeline Variables for deployment.

# Auth
NEXT_PUBLIC_AUTH_DISABLED=false
AUTH0_SECRET=
AUTH0_BASE_URL=
AUTH0_ISSUER_BASE_URL=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_CONNECTION=
AUTH0_AUDIENCE=
AUTH0_ROLE_SCOPE=

# Database (Azure Postgres in prod)
DATABASE_URL=
POSTGRES_CONNECTION_STRING=
AZURE_POSTGRES_CONNECTION_STRING=

# Supabase (for migration source; optional at runtime)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Azure Blob Storage
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER_NAME=project-plans

# Workday sync
WORKDAY_ISU_USER=
WORKDAY_ISU_PASS=

# MPP Parser
MPP_PARSER_URL=
NEXT_PUBLIC_MPP_PARSER_URL=
